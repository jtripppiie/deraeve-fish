<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DeRaeveFish" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/salmon</item>
        <item name="android:navigationBarColor">@color/river_dark</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowNoTitle">true</item>
        <!-- Dark window + Android 12+ system splash so the launch/loading screen
             matches the app's dark river background (no white flash) and shows
             the salmon icon while the activity starts. -->
        <item name="android:windowBackground">@color/river_dark</item>
        <item name="android:windowSplashScreenBackground">@color/river_dark</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
    </style>
</resources>
